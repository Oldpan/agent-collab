{
  "name": "@agent-collab/node",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent node server — HTTP + WebSocket gateway to ACP agents",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@agent-collab/wire-types": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.3.3",
    "@fastify/websocket": "^11.2.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}
